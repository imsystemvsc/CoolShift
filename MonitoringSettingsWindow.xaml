<Window x:Class="ParkToggleWpf.MonitoringSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:monitoring="clr-namespace:ParkToggleWpf.Monitoring"
        mc:Ignorable="d"
        Title="Monitoring Settings"
        Height="520"
        Width="460"
        MinHeight="420"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="#1B1D26"
        BorderBrush="#2C2E37"
        BorderThickness="1">
    <Window.Resources>
        <Style x:Key="OverlayScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#151822" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton" Command="{x:Static ScrollBar.LineUpCommand}" Style="{StaticResource OverlayScrollBarRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton" Command="{x:Static ScrollBar.LineDownCommand}" Style="{StaticResource OverlayScrollBarRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#8CA9FF" Opacity="0.75" CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Height" Value="{Binding Width, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="Root" Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                <Setter TargetName="DecreaseButton" Property="Command" Value="{x:Static ScrollBar.LineLeftCommand}" />
                                <Setter TargetName="IncreaseButton" Property="Command" Value="{x:Static ScrollBar.LineRightCommand}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Grid.Row="0"
                    Margin="0 0 0 16"
                    VerticalAlignment="Center">
            <TextBlock Text="Available Sensors"
                       Foreground="#EEF0F4"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="  (toggle sensors to show on the Monitoring tab)"
                       Foreground="#9AA0AE"
                       FontSize="12"
                       VerticalAlignment="Center" />
        </StackPanel>

        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Margin="0 0 0 12"
                 Height="32"
                 Background="#1F212B"
                 Foreground="#EEF0F4"
                 BorderBrush="#2C2E37"
                 BorderThickness="1"
                 Padding="12 4"
                 TextChanged="SearchBox_TextChanged"
                 VerticalContentAlignment="Center" />

        <Border Grid.Row="2"
                Background="#1B1D26"
                BorderBrush="#2C2E37"
                BorderThickness="1"
                CornerRadius="12"
                Padding="2">
            <Grid>
                <TreeView x:Name="SensorTree"
                          ItemsSource="{Binding SensorTreeNodes}"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="#EEF0F4"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <TreeView.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBarStyle}" />
                        <HierarchicalDataTemplate DataType="{x:Type monitoring:MonitoringHardwareNode}" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#EEF0F4"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0 10 0 4" />
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type monitoring:MonitoringSensorGroupNode}" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#EEF0F4"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0 4 0 2" />
                        </HierarchicalDataTemplate>
                        <DataTemplate DataType="{x:Type monitoring:MonitoringSensorLeafNode}">
                            <Border Background="#1F212B"
                                    CornerRadius="8"
                                    Padding="8"
                                    Margin="0 4">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding Sensor.IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Focusable="False" />
                                    <StackPanel Grid.Column="1"
                                                Margin="8 0 0 0"
                                                Orientation="Vertical">
                                        <TextBlock Text="{Binding Sensor.SensorDisplayName}"
                                                   Foreground="#EEF0F4"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Sensor.GroupDisplayName}"
                                                   Foreground="#9AA0AE"
                                                   FontSize="11" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Margin="16 0 0 0"
                                               Text="{Binding Sensor.CurrentDisplay}"
                                               Foreground="#9AA0AE"
                                               FontSize="12"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True" />
                            <Setter Property="Foreground" Value="#EEF0F4" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <TextBlock x:Name="EmptyTreeMessage"
                           Text="No sensors match your filter."
                           Foreground="#9AA0AE"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 16 0 0">
            <Button Content="Close"
                    Width="110"
                    Padding="18 10"
                    Foreground="#EEF0F4"
                    Background="#1F212B"
                    BorderBrush="#2C2E37"
                    BorderThickness="1"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>

